{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bunny-builder-game",
  "compatibility_date": "2026-04-13",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "ADMIN_WALLET": "0x0000000000000000000000000000000000000000",
    "CONTRACT_ADDRESS": "0x0000000000000000000000000000000000000000",
    "ARC_RPC_URL": "https://rpc.arctest.io",
    "USDC_ADDRESS": "0x0000000000000000000000000000000000000001",
    "EURC_ADDRESS": "0x0000000000000000000000000000000000000002"
  }
}
